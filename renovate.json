{
  "$schema": "https://renovatebot.com",
  "extends": ["config:recommended", ":enablePreCommit"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "branchConcurrentLimit": 0,
  "rangeStrategy": "update-lockfile",
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchManagers": ["pre-commit", "devcontainer"],
      "matchUpdateTypes": ["major"],
      "automerge": true
    },
    {
      "matchPackageNames": ["uv"],
      "matchUpdateTypes": ["major"],
      "automerge": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": false
  }
}
