{
  "$schema": "https://renovatebot.com",
  "extends": ["config:recommended"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "branchConcurrentLimit": 0,
  "rangeStrategy": "update-lockfile",
  "packageRules": [
    {
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)\\.devcontainer/devcontainer\\.json$/"],
      "matchStrings": [
        "\"image\":\\s*\"mcr\\.microsoft\\.com/devcontainers/python:(?<prefix>[^-]+)-(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "python",
      "datasourceTemplate": "python-version",
      "autoReplaceStringTemplate": "\"image\": \"mcr.microsoft.com/devcontainers/python:1-{{{newValue}}}\""
    }
  ],
  "lockFileMaintenance": { "enabled": false }
}
