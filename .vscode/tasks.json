{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Pytest tests",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "pytest", "tests/"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Pytest tests with coverage",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "pytest",
        "tests/",
        "--cov=aiovodafone",
        "--cov-report=term-missing:skip-covered"
      ],
      "group": "test",
      "problemMatcher": []
    }
  ]
}
